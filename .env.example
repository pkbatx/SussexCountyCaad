# Required ---------------------------------------------------------------------
CALLS_DIR=/absolute/path/to/calls
CAAD_DB_PATH=/absolute/path/to/runtime/data/caad.sqlite

# HTTP -------------------------------------------------------------------------
API_PORT=3000
# Lock CORS to this origin in production. Leave unset in dev (allows any origin).
FRONTEND_ORIGIN=

# Observability ----------------------------------------------------------------
LOG_LEVEL=info                    # trace | debug | info | warn | error

# AI provider ------------------------------------------------------------------
AI_PROVIDER=anthropic             # anthropic | openai
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI is required for audio transcription and embeddings even when
# AI_PROVIDER=anthropic. Strict-JSON completion only falls through to OpenAI
# when AI_PROVIDER=openai.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe
OPENAI_EMBEDDINGS_MODEL=text-embedding-3-small
OPENAI_EMBEDDINGS_BATCH_SIZE=64
OPENAI_EMBEDDINGS_PRECOMPUTE=false

# Mapbox -----------------------------------------------------------------------
MAPBOX_ACCESS_TOKEN=
MAPBOX_STYLE=mapbox://styles/mapbox/navigation-night-v1
MAPBOX_GEOCODE_BBOX=
MAPBOX_GEOCODE_LIMIT=5
MAPBOX_GEOCODE_TYPES=address,poi,place

# Notifications ----------------------------------------------------------------
NOTIFY_ENABLED=false
NOTIFY_INCIDENT_DEDUPE_WINDOW_SECONDS=900
GROUPME_BOT_ID=
DISCORD_WEBHOOK_URL=

# Pipeline tuning --------------------------------------------------------------
GROUPING_WINDOW_MINUTES=120
GROUPING_MAX_CANDIDATES=20
GROUPING_MAX_SIGNALS=4
GROUPING_CONFIDENCE_THRESHOLD=0.7
DIGEST_REFRESH_HOURS=2
DIGEST_REFRESH_CALL_THRESHOLD=5
RE_ALERT_WINDOW_MINUTES=7
FEEDBACK_CONFIDENCE_PENALTY=0.05
FEEDBACK_MAX_PENALTY=0.2

# Reference data ---------------------------------------------------------------
REFERENCE_POI_PATH=
REFERENCE_STREET_TOWNS_PATH=
REFERENCE_DATA_MAX_CANDIDATES=10
REFERENCE_AMBIGUOUS_AGENCIES=Lakeland,Tri-Pod,Blue Ridge
AGENCY_REGISTRY_RETENTION_DAYS=30
TRANSCRIPTION_HINT_MAX_CANDIDATES=8

# UI labels --------------------------------------------------------------------
UI_UNSPECIFIED_LABEL=Unspecified
UI_UNMAPPED_LABEL=Unmapped
UI_UNKNOWN_AGENCY_LABEL=Unknown
